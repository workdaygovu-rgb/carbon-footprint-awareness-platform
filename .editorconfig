# EditorConfig keeps whitespace and encoding consistent across editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,json,css,html,yml,yaml}]
indent_size = 2

[*.md]
# Trailing spaces are meaningful (hard line breaks) in Markdown.
trim_trailing_whitespace = false
