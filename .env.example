# ── Carbon Footprint Awareness Platform — environment template ──
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# In Cloud Run these are set via --set-env-vars; credentials come from the
# runtime service account (Application Default Credentials) — no key files.

# Google Cloud project + region (used by Vertex AI and Firestore)
PROJECT_ID=virtual-prompt-week-3
REGION=us-central1

# Personalized insights via Vertex AI (Gemini).
# USE_GEMINI=false makes the app use the deterministic rule-based engine only
# (handy for local dev/tests without GCP credentials).
USE_GEMINI=true
GEMINI_MODEL=gemini-2.5-flash

# Persistence. USE_FIRESTORE=false uses an in-memory store (local/tests).
USE_FIRESTORE=true

# Comma-separated allowed CORS origins for the API.
# In production the SPA is same-origin, so this is mainly for local dev.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
